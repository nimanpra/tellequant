# Required: how the worker phones home to the Tellequant Next.js API.
TELLEQUANT_API_BASE_URL=https://tellequant.yourdomain.com

# Required: must match VOICE_WORKER_SHARED_SECRET in the Next.js app.
# Used to HMAC-sign every request to /api/internal/*.
VOICE_WORKER_SHARED_SECRET=change-me

# -----------------------------------------------------------------------------
# Everything below is OPTIONAL. By default the worker is BYOK — at the start of
# each call it fetches the caller's own provider keys from the Tellequant API
# (stored encrypted on their org). The env vars here only act as fallbacks for
# single-tenant self-host deployments where you want one set of keys for all
# calls on this worker. Leave them blank for multi-tenant / cloud mode.
# -----------------------------------------------------------------------------

# Deepgram (STT + TTS)
DEEPGRAM_API_KEY=

# LLM — Groq Llama 3.3 70B is the default (fast TTFT).
GROQ_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# Optional alternate TTS
CARTESIA_API_KEY=

# Telephony (outbound dialer) — at least one is required to place outbound calls.
TELNYX_API_KEY=
TELNYX_CONNECTION_ID=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Worker HTTP/WS port
PORT=8787
