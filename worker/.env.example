# API base (your Vercel deployment or ngrok URL for dev)
TELLEQUANT_API_BASE_URL=https://tellequant.yourdomain.com

# Shared secret — must match VOICE_WORKER_SHARED_SECRET in the Next.js app
VOICE_WORKER_SHARED_SECRET=change-me

# Deepgram (STT + TTS)
DEEPGRAM_API_KEY=

# LLM — Groq Llama 3.3 70B is the default (free tier, fastest TTFT for voice)
GROQ_API_KEY=
# Optional alternates
GEMINI_API_KEY=
OPENAI_API_KEY=

# Optional: alternate TTS
CARTESIA_API_KEY=

# Telephony (outbound dialer) — set at least one.
# Telnyx is the default — cheaper per minute than Twilio.
TELNYX_API_KEY=
TELNYX_CONNECTION_ID=

# Twilio (fallback)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Worker HTTP/WS port
PORT=8787
