########################################
# Tellequant — environment variables
########################################

# --- Public app ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Tellequant

# --- Supabase (auth + postgres + pgvector + storage) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- LLM ---
# Default is Groq Llama 3.3 70B — fastest TTFT for voice, generous free tier.
LLM_PRIMARY=groq                         # groq | openai | gemini | anthropic
GROQ_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# --- Embeddings (for RAG) ---
EMBEDDING_PROVIDER=openai                # openai | voyage | cohere | jina
EMBEDDING_MODEL=text-embedding-3-small   # 1536 dim
VOYAGE_API_KEY=
COHERE_API_KEY=
JINA_API_KEY=

# --- Speech-to-Text ---
STT_PROVIDER=deepgram                    # deepgram | groq | openai
DEEPGRAM_API_KEY=

# --- Text-to-Speech ---
TTS_PROVIDER=cartesia                    # cartesia | deepgram | openai | elevenlabs
CARTESIA_API_KEY=
ELEVENLABS_API_KEY=

# --- Telephony ---
# Default is Telnyx (~50% cheaper per minute than Twilio). Twilio remains supported as fallback.
TELEPHONY_PROVIDER=telnyx                # telnyx | twilio

# Telnyx — https://portal.telnyx.com
TELNYX_API_KEY=
# TeXML application ID whose voice webhook points at ${PUBLIC_WEBHOOK_URL}/api/telnyx/voice
TELNYX_CONNECTION_ID=
# Optional: used by future webhook-signature verification
TELNYX_PUBLIC_KEY=

# Twilio (fallback / legacy numbers)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_APP_SID=

# Base URL that Telnyx/Twilio webhooks should hit — use ngrok / Cloudflare tunnel in dev
PUBLIC_WEBHOOK_URL=http://localhost:3000

# --- Voice worker (Python, Pipecat based) ---
# HTTP base used by /api/campaigns/:id/start to kick the dial loop
WORKER_URL=http://localhost:8787
# HMAC shared secret — worker signs API calls with this (x-tellequant-worker-key header)
VOICE_WORKER_SHARED_SECRET=change-me-to-32+-random-chars
# wss:// URL that Media Streams should dial for inbound calls (run `ngrok http 8787`)
VOICE_WORKER_WS_URL=wss://your-ngrok-subdomain.ngrok.app/twilio
# Legacy — still used by /api/campaigns/:id/start to bearer-auth the kick endpoint
WORKER_SHARED_SECRET=change-me

# --- Stripe (billing) ---
# 1. Create Products/Prices in Stripe Dashboard (recurring monthly, USD).
# 2. Paste the resulting price_... IDs below.
# 3. After `stripe listen --forward-to .../api/billing/webhook`, copy the whsec_... it prints.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_ID_PRO=
